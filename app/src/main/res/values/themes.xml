<resources>
    <!--
      Manifest/launch theme only. Compose content in MainActivity uses
      MaterialTheme (Material 3) for everything after the first frame; this
      theme's job is just to control the window before that, so it doesn't
      pull in the com.google.android.material dependency.
    -->
    <style name="Theme.GameSpacePro" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>
</resources>
