<resources>
    <!-- App luôn dùng giao diện tối (xem GameSpaceTheme.kt) — windowBackground khớp màu
         nền GsBackgroundBottom để tránh nháy trắng lúc khởi động trước khi Compose vẽ xong. -->
    <style name="Theme.GameSpace" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">#FF0B1830</item>
        <item name="android:statusBarColor">#FF0B1830</item>
        <item name="android:navigationBarColor">#FF0B1830</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Theme riêng cho SplashScreen API (androidx.core.splashscreen — hoạt động đồng nhất
         API 26+ nhờ lớp compat của thư viện, không chỉ API 31+ như SplashScreen gốc của
         Android 12). MainActivity dùng theme này trong Manifest; sau khi installSplashScreen()
         chạy xong, hệ thống tự chuyển sang postSplashScreenTheme (Theme.GameSpace) — không cần
         tự set lại theme bằng code. -->
    <style name="Theme.GameSpace.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF0B1830</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_full</item>
        <item name="windowSplashScreenAnimationDuration">600</item>
        <item name="postSplashScreenTheme">@style/Theme.GameSpace</item>
    </style>
</resources>
